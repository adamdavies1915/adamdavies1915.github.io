---
import { Image } from 'astro:assets';
import Card from '../ui/Card.astro';

interface Props {
  post: any;
}

const { post } = Astro.props;

function formatDate(date: Date): string {
  return date.toISOString().split('T')[0]; // YYYY-MM-DD
}
---

<article class="group">
  <Card href={`/blog/${post.slug}`} title={`~/blog/${post.slug}.md`}>
    <!-- Image -->
    {post.data.image && (
      <div class="aspect-video overflow-hidden">
        <Image
          src={post.data.image}
          alt={post.data.title}
          class="w-full h-full object-cover transition-transform duration-500 group-hover:scale-105"
        />
      </div>
    )}

    <!-- Content -->
    <div class="p-6">
      <!-- File path + date -->
      <p class="font-[var(--font-mono)] text-xs text-gray-500 mb-3">
        <span class="text-[var(--color-terminal-green)]">-rw-r--r--</span>
        <span class="ml-2 text-[var(--color-terminal-cyan)]">{formatDate(post.data.date)}</span>
        <span class="ml-2">{post.slug}.md</span>
      </p>

      <!-- Title -->
      <h3 class="font-[var(--font-display)] text-xl font-bold text-gray-100 mb-3 group-hover:text-[var(--color-terminal-green)] transition-colors">
        {post.data.title}
      </h3>

      <!-- Excerpt -->
      <p class="text-gray-400 text-sm line-clamp-3">
        {post.data.subtitle || post.body?.slice(0, 150) + '...'}
      </p>

      <!-- Tags -->
      {post.data.tags && (
        <div class="flex flex-wrap gap-2 mt-4">
          {post.data.tags.slice(0, 3).map((tag: string) => (
            <span class="font-[var(--font-mono)] text-xs px-2 py-1 bg-[var(--color-dark-600)] text-[var(--color-terminal-cyan)]">
              [{tag}]
            </span>
          ))}
        </div>
      )}
    </div>
  </Card>
</article>
