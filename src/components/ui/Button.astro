---
interface Props {
  variant?: 'primary' | 'outline';
  size?: 'sm' | 'md' | 'lg';
  href?: string;
  class?: string;
  external?: boolean;
}

const {
  variant = 'primary',
  size = 'md',
  href,
  class: className,
  external = false,
} = Astro.props;

const baseStyles =
  'font-[var(--font-mono)] tracking-wide transition-all duration-200 relative inline-flex items-center justify-center whitespace-nowrap';

const variants = {
  primary:
    'bg-[var(--color-terminal-green)] text-[var(--color-dark-900)] border-3 border-[var(--color-terminal-green)] hover:shadow-brutal-green hover:-translate-x-1 hover:-translate-y-1 font-bold',
  outline:
    'bg-transparent text-[var(--color-terminal-green)] border-3 border-[var(--color-terminal-green)] hover:bg-[var(--color-terminal-green)] hover:text-[var(--color-dark-900)] font-bold',
};

const sizes = {
  sm: 'px-3 py-1.5 text-xs gap-1.5',
  md: 'px-5 py-2.5 text-sm gap-2',
  lg: 'px-6 py-3 text-base gap-2',
};

const Element = href ? 'a' : 'button';
const externalProps = external ? { target: '_blank', rel: 'noopener noreferrer' } : {};
---

<Element
  href={href}
  class:list={[baseStyles, variants[variant], sizes[size], className]}
  {...externalProps}
>
  {variant === 'primary' && (
    <span class="opacity-60">$</span>
  )}
  {variant === 'outline' && (
    <span class="opacity-60">[</span>
  )}
  <slot />
  {variant === 'outline' && (
    <span class="opacity-60">]</span>
  )}
</Element>
