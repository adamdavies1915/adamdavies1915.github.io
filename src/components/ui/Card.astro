---
interface Props {
  href?: string;
  class?: string;
  hover?: boolean;
  title?: string;
}

const { href, class: className, hover = true, title } = Astro.props;

const Element = href ? 'a' : 'div';
---

<Element
  href={href}
  class:list={[
    'flex flex-col border border-white/10 bg-[var(--color-dark-800)] overflow-hidden transition-all duration-300',
    hover && 'hover:border-[var(--color-terminal-green)] hover:shadow-brutal-green hover:-translate-x-1 hover:-translate-y-1',
    href && 'cursor-pointer',
    className,
  ]}
>
  <!-- Terminal title bar -->
  {title && (
    <div class="px-4 py-1.5 border-b border-white/5 bg-[var(--color-dark-900)]">
      <span class="font-[var(--font-mono)] text-[10px] text-gray-500">{title}</span>
    </div>
  )}
  <slot />
</Element>
