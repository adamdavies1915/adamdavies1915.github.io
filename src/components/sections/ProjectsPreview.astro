---
import Button from '../ui/Button.astro';
import Card from '../ui/Card.astro';
import type { GitHubProject } from '../../lib/github';

interface Props {
  projects: GitHubProject[];
}

const { projects } = Astro.props;
---

<section class="py-24">
  <div class="container mx-auto px-6">
    <!-- Section header -->
    <div class="mb-12 animate-on-scroll">
      <h2 class="font-[var(--font-display)] text-4xl font-bold text-gray-100">
        Side <span class="text-[var(--color-terminal-green)]">Projects</span>
      </h2>
    </div>

    <!-- Projects grid -->
    <div class="grid md:grid-cols-2 gap-8">
      {projects.map((project, i) => (
        <div class="animate-on-scroll" style={`animation-delay: ${i * 0.1}s;`}>
          <Card href={project.liveUrl || project.github}>
            <div class="p-6">
              {project.emoji && (
                <span class="text-4xl mb-4 block">{project.emoji}</span>
              )}

              <h3 class="font-[var(--font-display)] text-xl font-bold text-gray-100 mb-2">
                {project.title}
              </h3>

              <p class="text-gray-400 text-sm mb-4">
                {project.summary ? project.summary.split('\n')[0].slice(0, 150) : project.description}
              </p>

              {project.tags && project.tags.length > 0 && (
                <div class="flex flex-wrap gap-2">
                  {project.tags.slice(0, 3).map((tag: string) => (
                    <span class="font-[var(--font-mono)] text-xs px-2 py-1 bg-[var(--color-dark-600)] text-[var(--color-terminal-cyan)]">
                      {tag}
                    </span>
                  ))}
                </div>
              )}
            </div>
          </Card>
        </div>
      ))}
    </div>

    <div class="text-center mt-12 animate-on-scroll">
      <Button href="/projects" variant="outline">View All Projects</Button>
    </div>
  </div>
</section>
