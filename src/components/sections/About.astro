---
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';
---

<section class="py-24 relative">
  <div class="container mx-auto px-6">
    <div class="max-w-2xl animate-on-scroll">
      <h2 class="font-[var(--font-display)] text-4xl font-bold text-gray-100 mb-6">
        About <span class="text-[var(--color-terminal-green)]">Me</span>
      </h2>
      <p class="text-gray-300 leading-relaxed mb-6">{siteConfig.blurb}</p>

      <!-- Skills -->
      <div class="flex flex-wrap gap-2 mb-8">
        {siteConfig.skills.map((skill) => (
          <span
            class="font-[var(--font-mono)] text-xs px-3 py-1 border border-[var(--color-terminal-green)]/40 text-[var(--color-terminal-green)]"
          >
            {skill.name}
          </span>
        ))}
      </div>

      <Button href="/about" variant="outline">Read More</Button>
    </div>
  </div>
</section>
