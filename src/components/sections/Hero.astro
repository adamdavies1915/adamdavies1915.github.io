---
import Button from '../ui/Button.astro';
import { siteConfig } from '../../data/site';
---

<section class="min-h-screen flex items-center">
  <div class="container mx-auto px-6 pt-20">
    <div class="max-w-3xl">
      <!-- Terminal prompt -->
      <div class="font-[var(--font-mono)] text-sm mb-6 flex items-center gap-2">
        <span class="text-[var(--color-terminal-cyan)]">~</span>
        <span class="text-[var(--color-terminal-green)]">$</span>
        <span class="text-gray-400">whoami</span>
      </div>

      <!-- Name -->
      <h1 class="font-[var(--font-display)] text-6xl md:text-8xl font-bold mb-6 leading-tight text-[var(--color-terminal-green)]">
        {siteConfig.author}
      </h1>

      <!-- Role -->
      <p class="font-[var(--font-mono)] text-xl md:text-2xl text-[var(--color-terminal-cyan)] mb-8">
        <span class="text-[var(--color-terminal-green)]">&gt;</span> Full Stack Software Engineer
      </p>

      <!-- Blurb -->
      <p class="text-lg text-gray-400 max-w-2xl mb-12 leading-relaxed">
        {siteConfig.blurb}
      </p>

      <!-- CTAs -->
      <div class="flex flex-wrap gap-4 mb-12">
        <Button href="/about" variant="primary" size="lg">About Me</Button>
        <Button href="/blog" variant="outline" size="lg">Blog</Button>
        <Button href="/projects" variant="outline" size="lg">Projects</Button>
      </div>

      <!-- Social links -->
      <div class="flex items-center gap-3">
        {siteConfig.social.map((item) => (
          <a
            href={item.link}
            target="_blank"
            rel="noopener noreferrer"
            class="p-3 border border-white/10 hover:border-[var(--color-terminal-green)] hover:text-[var(--color-terminal-green)] transition-all text-gray-400"
            aria-label={item.name}
          >
            <Fragment set:html={item.icon} />
          </a>
        ))}
      </div>
    </div>
  </div>
</section>
